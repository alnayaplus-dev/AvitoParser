{
  "manifest_version": 3,
  "name": "Avito Парсер",
  "version": "0.65",
  "description": "Парсинг статистики, фраз и семантики прямо на Avito",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.avito.ru/*"],
  "icons": {
    "128": "icon1024.png"
  },
  "action": {
    "default_icon": "icon1024.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.avito.ru/*"],
      "js": ["content.js"]
    }
  ]
}